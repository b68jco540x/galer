{
  "$schema": "https://raw.githubusercontent.com/skymethod/denoflare/v0.7.0/common/config.schema.json",
  "scripts": {
    "galer": {
      "path": "bot.ts",
      "localPort": 3030,
      "bindings": {
        "BOT_TOKEN":       { "value": "PLACEHOLDER_BOT_TOKEN" },
        "GROQ_API_KEY":    { "value": "PLACEHOLDER_GROQ_API_KEY" },
        "OWNER_ID":        { "value": "PLACEHOLDER_OWNER_ID" },
        "GEMINI_API_KEY":  { "value": "PLACEHOLDER_GEMINI_API_KEY" },
        "TAVILY_API_KEY":  { "value": "PLACEHOLDER_TAVILY_API_KEY" },
        "LOG_CHAT_ID":     { "value": "PLACEHOLDER_LOG_CHAT_ID" },
        "KV": { "kvNamespace": "PLACEHOLDER_KV_NAMESPACE_ID" }
      },
      "workersDev": true
    }
  },
  "profiles": {
    "main": {
      "accountId": "PLACEHOLDER_CF_ACCOUNT_ID",
      "apiToken":  "PLACEHOLDER_CF_API_TOKEN"
    }
  }
}
